# Keep the build context small: the Dockerfile only needs Cargo manifests +
# crates/ sources. Everything below is rebuilt inside the image or irrelevant.
# (test/ holds the dSYM fixtures used only by the SQL suite — mounted into the
# container at test time, never baked into the image.)
/target
**/target
/build
.git
.github
.gitignore
test
data
duckdb_unittest_tempdir
**/*.rs.bk
.DS_Store
